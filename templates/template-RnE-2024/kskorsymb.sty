\NewDocumentCommand \addUserSymbol { m }
{
	\prop_gput_from_keyval:Nn \g_UserSymb_prop { #1 }
}

\NewDocumentCommand \clearUserSymbol {}
{
	\prop_gclear:N \g_UserSymb_prop
}

\bool_if:nT
{
	( ! \opt_minimal_bool ) && ( ! \opt_minimalplus_bool )
}
{ 
	\addUserSymbol{
			*	=  ※,
			{=}	=  ☞,
			?	=  ◎,
			X	= {\_UnBatang_font ×},
	}
}

\NewDocumentCommand \removeDefaultSymbol { m }   %% not indended to use practically
{
	\clist_set:Nn \l_tmpa_clist { #1 }
	\clist_map_inline:Nn \l_tmpa_clist
	{
		\prop_gremove:Nn \g_KorSymb_prop { ##1 }
	}
}

\NewDocumentCommand \removeUserSymbol { m }
{
	\clist_set:Nn \l_tmpa_clist { #1 }
	\clist_map_inline:Nn \l_tmpa_clist
	{
		\prop_gremove:Nn \g_UserSymb_prop { ##1 }
	}
}


%%%% 0.6
\NewDocumentCommand \myQuoteSymbol {}
{
	\bool_if:NTF \korsym_largequotestatus_bool
	{
		”
		\bool_gset_false:N \korsym_largequotestatus_bool
	}
	{
		“
		\bool_gset_true:N \korsym_largequotestatus_bool
	}
}

\NewDocumentCommand \myQuoteSymbolDeep {}
{
	\bool_if:NTF \l_tmpa_bool
	{
		”
		\bool_gset_false:N \l_tmpa_bool
	}
	{
		“
		\bool_gset_true:N \l_tmpa_bool
	}
}

\NewDocumentCommand \mysmallQuoteSymbol {}
{
	\bool_if:NTF \korsym_smallquotestatus_bool
	{
		’
		\bool_gset_false:N \korsym_smallquotestatus_bool
	}
	{
		‘
		\bool_gset_true:N \korsym_smallquotestatus_bool
	}
}

\NewDocumentCommand \mysmallQuoteSymbolDeep {}
{
	\bool_if:NTF \l_tmpb_bool
	{
		’
		\bool_gset_false:N \l_tmpb_bool
	}
	{
		‘
		\bool_gset_true:N \l_tmpb_bool
	}
}

\NewDocumentCommand \defineextraparenmark { m }
{
	\tl_set:Nn \l_tmpa_tl { #1 }
	\tl_gset:Nx \extraParenMarkOpen { \tl_item:Nn \l_tmpa_tl { 1 } }
	\tl_gset:Nx \extraParenMarkClose { \tl_item:Nn \l_tmpa_tl { 2 } }
}

\defineextraparenmark{〔〕}

\NewDocumentCommand \myExtraParenMark {}
{
	\bool_if:NTF \korsym_parenstatus_bool
	{
		\extraParenMarkClose
		\bool_gset_false:N \korsym_parenstatus_bool
	}
	{
		\extraParenMarkOpen
		\bool_gset_true:N \korsym_parenstatus_bool
	}	
}

