\ProvidesExplPackage{kskorsymb}
	{2024/08/30}
	{v0.6.3}
	{shorthands for korean punctuations}

\RequirePackage{l3keys2e}
\RequirePackage{etoolbox}

\keys_define:nn { kskorsym }
{
	localenv	.bool_set:N = \opt_localenv_bool,
	minimal		.bool_set:N = \opt_minimal_bool,
	minimalplus	.bool_set:N = \opt_minimalplus_bool
}

\keys_set:nn { kskorsym }
{
	localenv = false,
	minimal  = false,
	minimalplus = false
}

\ProcessKeysOptions { kskorsym }

\RequirePackage{iftex}
\RequirePackage{etoolbox}

\ifx\ifXeTeX\ifLuaTeX
	\providecommand*\_UnBatang_font {}
	\providecommand*\_HCRBatang_font {}
\else
\AtEndPreamble{
    \NewDocumentCommand \_UnBatang_font {} {
    	\fontspec{UnBatang.ttf}[BoldFont=UnBatangBold.ttf]
		\cs_if_exist:NT \hangulfontspec {
        	\hangulfontspec{UnBatang.ttf}[BoldFont=UnBatangBold.ttf]
		}
    }
    \NewDocumentCommand \_HCRBatang_font {} {
    	\fontspec{HANBatang-LVT.ttf}[BoldFont=HANBatangB-LVT.ttf]
		\cs_if_exist:NT \hangulfontspec {
	    	\hangulfontspec{HANBatang-LVT.ttf}[BoldFont=HANBatangB-LVT.ttf]
		}
    }
}
\fi

\let\ORG_RQRQ"

\prop_new:N \g_UserSymb_prop 
\bool_new:N \korsym_parenstatus_bool
\bool_new:N \korsym_largequotestatus_bool
\bool_new:N \korsym_smallquotestatus_bool

\bool_if:NTF \opt_minimal_bool
{
    \prop_const_from_keyval:Nn \g_KorSymb_prop
    {
    	.	=  ·, 
	}
}
{
	\bool_if:NTF \opt_minimalplus_bool
	{
	    \prop_const_from_keyval:Nn \g_KorSymb_prop
	    {
	    	.	=  ·, 
	    	\~	= {\_UnBatang_font ∼},
	    	-	= {\_HCRBatang_font …},
	    	:	= ：,
	    	'	= \mysmallQuoteSymbol,
	    	"	= \myQuoteSymbol,
			\' 	= \mysmallQuoteSymbolDeep,
			\"	= \myQuoteSymbolDeep,
			/	= \myExtraParenMark,
		}
	}
	{
	    \prop_const_from_keyval:Nn \g_KorSymb_prop
	    {
	    	.	=  ·, 
	    	\.	=  。,
	    	\,	=  、,
	    	<	=  〈,
	    	>	=  〉,
	    	(	=  《,
	    	)	=  》,
	    	[	=  「,
	    	]	=  」,
	    	\{	=  『,
	    	\}	=  』,
	    	\~	= {\_UnBatang_font ∼},
	%%%    	-	= \myEllipsisSymbol,
			- 	= {\_HCRBatang_font …},
	    	:	= ：,
	    	'	= \mysmallQuoteSymbol,
	    	"	= \myQuoteSymbol,
			\' 	= \mysmallQuoteSymbolDeep,
			\"	= \myQuoteSymbolDeep,
	    	/	= \myExtraParenMark,
	    }
	}
}

\char_set_catcode_active:N \"

\bool_if:NF \opt_localenv_bool
{
	\AtBeginDocument {
		\catcode`\"=\active
	}
}

%%% \protected? 
\def"{
	\mode_if_math:F
	{
    	\peek_catcode:NTF \c_space_token
    	{ \texorpdfstring { \ORG_RQRQ } {} }
    	{ \__shorthand_kor_punctuations }
	}
}

\NewDocumentCommand \__shorthand_kor_punctuations { m }
{
	\group_begin:

	\prop_if_in:NnTF \g_KorSymb_prop { #1 }
	{
		\prop_get:NnN \g_KorSymb_prop { #1 } \l_tmpa_tl
		\tl_use:N \l_tmpa_tl
	}
	{
		\prop_if_in:NnTF \g_UserSymb_prop { #1 }
		{
			\prop_get:NnN \g_UserSymb_prop { #1 } \l_tmpa_tl 
			\tl_use:N \l_tmpa_tl
		}
		{
			\texorpdfstring { \ORG_RQRQ #1 } { #1 }
		}
	}
	
	\group_end:
}

\NewDocumentCommand \escaperqcat  {} { \catcode`\"=12 }
\NewDocumentCommand \restorerqcat {} { \catcode`\"=\active }
\let\brr\escaperqcat %%% alias
\let\err\restorerqcat  %%% alias
\let\startkorsymbols\restorerqcat

